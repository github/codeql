case @swift_token.kind of
  0 = @swift_reserved_word
| 1 = @swift_token__expression
| 2 = @swift_token_as_operator
| 3 = @swift_token_bang
| 4 = @swift_token_bin_literal
| 5 = @swift_token_boolean_literal
| 6 = @swift_token_catch_keyword
